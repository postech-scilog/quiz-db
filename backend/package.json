{
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node src/server.ts",
    "dev": "NODE_ENV=development node --watch src/server.ts | pino-pretty",
    "check": "npm run check:types && npm run check:biome",
    "check:types": "tsc",
    "check:biome": "npx @biomejs/biome check",
    "fix": "npx @biomejs/biome check --write"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mime-types": "^3.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/validator": "^13.15.10",
    "pino-pretty": "^13.1.3"
  }
}
