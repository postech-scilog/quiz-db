{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022"],
    "module": "node18",
    "moduleResolution": "node16",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test/**/*.spec.ts"]
}
