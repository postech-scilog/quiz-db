{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022", "DOM"],
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@types/wicg-file-system-access"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test/**/*.spec.ts"]
}
